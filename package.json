{
  "name": "gaza-cash",
  "productName": "غزة كاش",
  "description": "نظام غزة كاش المتكامل لإدارة المبيعات ونقاط البيع، الفروع والمخازن، الحسابات والعملاء والموردين",
  "author": "Gaza Cash Team",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "electron:dev": "ELECTRON=true vite",
    "electron:build": "ELECTRON=true vite build && electron-builder",
    "electron:build:win": "ELECTRON=true vite build && electron-builder --win",
    "electron:build:portable": "ELECTRON=true vite build && electron-builder --win portable",
    "electron:build:nsis": "ELECTRON=true vite build && electron-builder --win nsis",
    "build:win": "ELECTRON=true vite build && electron-builder --win"
  },
  "build": {
    "appId": "com.gazacash.app",
    "productName": "غزة كاش",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "build/icon.ico",
      "artifactName": "${productName} ${version} ${target}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "غزة كاش",
      "uninstallDisplayName": "إلغاء تثبيت غزة كاش"
    }
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@react-pdf/renderer": "^4.5.1",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "arabic-persian-reshaper": "^1.0.1",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fs-extra": "^11.3.6",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-electron": "^1.1.0"
  }
}
